# MySQL 配置
MYSQL_ROOT_PASSWORD=your_root_password
MYSQL_DATABASE=todo_db
MYSQL_USER=todo
MYSQL_PASSWORD=your_password

# 后端连接数据库
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/todo_db?useUnicode=true&characterEncoding=utf-8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=todo
SPRING_DATASOURCE_PASSWORD=your_password
